---
import FlowNetwork from "./FlowNetwork.astro";
import MarketSnapshot from "./MarketSnapshot.astro";
---
<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">Wholesale energy · Munich · Warsaw · London</span>
      <h1>Energy, traded with precision <em>across Europe.</em></h1>
      <p class="lead">We move natural gas, LNG, power, oil and environmental products between Europe's markets — reading conditions fast, keeping price risk low, and standing behind every deal with the scale of the ORLEN Group.</p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">Partner with us <span class="arrow" aria-hidden="true">→</span></a>
        <a href="#trading" class="btn btn-ghost on-dark">What we trade</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat"><div class="n">5</div><div class="l">commodity markets</div></div>
        <div class="hero-stat"><div class="n">3</div><div class="l">European trading hubs</div></div>
        <div class="hero-stat"><div class="n">130<span style="color:var(--ember-light)">+</span></div><div class="l">years of Polish energy heritage</div></div>
      </div>
    </div>

    <div class="visual reveal">
      <FlowNetwork />
      <MarketSnapshot />
    </div>
  </div>
</section>
