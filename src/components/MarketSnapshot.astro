---
import type { Content } from "../i18n";

interface Props {
  content: Content["snapshot"];
}

const { content } = Astro.props;

const ROWS = [
  { base: 34.2, prec: 2, delta: "▲ 0.6%", deltaClass: "up", d: "0.6" },
  { base: 82.5, prec: 2, delta: "▼ 0.4%", deltaClass: "down", d: "0.4" },
  { base: 71.8, prec: 2, delta: "▲ 1.2%", deltaClass: "up", d: "1.2" },
  { base: 79.4, prec: 2, delta: "▲ 0.3%", deltaClass: "up", d: "0.3" },
];
---

<div class="snapshot" aria-label={`${content.title}, ${content.indicative}`}>
  <div class="snap-head">
    <span>{content.title}</span><span>{content.indicative}</span>
  </div>
  {
    ROWS.map((r, i) => (
      <div class="snap-row">
        <span class="name">{content.rows[i].name}</span>
        <span class="val" data-base={r.base} data-prec={r.prec}>
          {r.base.toFixed(r.prec)}
        </span>
        <span class={`delta ${r.deltaClass}`} data-d={r.d}>
          {r.delta}
        </span>
      </div>
    ))
  }
</div>
