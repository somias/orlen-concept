---
import type { Content } from "../i18n";

interface Props {
  content: Content["pillars"];
}

const { content } = Astro.props;
---

<section class="block">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">{content.eyebrow}</span>
      <h2>{content.h2}</h2>
    </div>
    <div class="pillars">
      {
        content.items.map((p) => (
          <div class="pillar reveal">
            <div class="num">{p.num}</div>
            <h3>{p.h3}</h3>
            <p>{p.body}</p>
            <div class="bar" />
          </div>
        ))
      }
    </div>
  </div>
</section>
