---
import type { Content } from "../i18n";

interface Props {
  content: Content["news"];
}

const { content } = Astro.props;
---

<section class="block" id="news" style="background:var(--paper-2)">
  <div class="wrap">
    <div class="news-head reveal">
      <div>
        <span class="eyebrow">{content.eyebrow}</span>
        <h2 style="margin-top:14px">{content.h2}</h2>
      </div>
      <a href="#news" class="btn btn-ghost">
        {content.allCta} <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
    <div class="news">
      {
        content.items.map((item) => (
          <a href="#news" class="news-card reveal">
            <time>{item.time}</time>
            <h3>{item.title}</h3>
            <span class="more">{item.more}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
