---
import type { Content } from "../i18n";

interface Props {
  content: Content["stats"];
}

const { content } = Astro.props;
---

<section class="stats" id="group">
  <div class="wrap">
    <div class="reveal">
      <span class="eyebrow" style="color:var(--ember-light)">{content.eyebrow}</span>
    </div>
    <div class="stat-grid" style="margin-top:34px">
      {
        content.items.map((item) => (
          <div class="stat reveal">
            <div class="n" set:html={item.n} />
            <div class="l">{item.l}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
