---
import type { Content, Lang } from "../i18n";
import { LANGS, LANG_HREF, LANG_LABEL } from "../i18n";
import gbFlag from "flag-icons/flags/4x3/gb.svg";
import deFlag from "flag-icons/flags/4x3/de.svg";
import plFlag from "flag-icons/flags/4x3/pl.svg";

interface Props {
  content: Content;
  lang: Lang;
}

const { content, lang } = Astro.props;
const t = content.nav;

const flagSrc = (m: unknown): string =>
  typeof m === "string" ? m : (m as { src: string }).src;
const FLAG_SRC: Record<Lang, string> = {
  en: flagSrc(gbFlag),
  de: flagSrc(deFlag),
  pl: flagSrc(plFlag),
};
---

<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a class="brand" href={LANG_HREF[lang] + "#top"}>
      <span class="mark">ORLEN</span><span>Energy&nbsp;Trading</span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="#trading">{t.trading}</a>
      <a href="#trading">{t.supply}</a>
      <a href="#trading">{t.services}</a>
      <a href="#group">{t.group}</a>
      <a href="#news">{t.news}</a>
    </nav>
    <div class="nav-right">
      <nav class="lang" aria-label={content.langSwitcher.aria}>
        {
          LANGS.map((l) =>
            l === lang ? (
              <b class="lang-item is-active" aria-current="true">
                <img class="flag" src={FLAG_SRC[l]} alt="" />
                {LANG_LABEL[l]}
              </b>
            ) : (
              <a class="lang-item" href={LANG_HREF[l]} hreflang={l} lang={l}>
                <img class="flag" src={FLAG_SRC[l]} alt="" />
                {LANG_LABEL[l]}
              </a>
            )
          )
        }
      </nav>
      <a href="#contact" class="btn btn-primary nav-cta">
        {t.cta} <span class="arrow" aria-hidden="true">→</span>
      </a>
      <button
        type="button"
        class="nav-toggle"
        id="navToggle"
        aria-label="Toggle menu"
        aria-controls="mobileMenu"
        aria-expanded="false"
      >
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-menu" id="mobileMenu" hidden>
    <nav class="mobile-links" aria-label="Mobile primary">
      <a href="#trading">{t.trading}</a>
      <a href="#trading">{t.supply}</a>
      <a href="#trading">{t.services}</a>
      <a href="#group">{t.group}</a>
      <a href="#news">{t.news}</a>
    </nav>
    <div class="mobile-foot">
      <nav class="mobile-lang" aria-label={content.langSwitcher.aria}>
        {
          LANGS.map((l) =>
            l === lang ? (
              <b class="lang-item is-active" aria-current="true">
                <img class="flag" src={FLAG_SRC[l]} alt="" />
                {LANG_LABEL[l]}
              </b>
            ) : (
              <a class="lang-item" href={LANG_HREF[l]} hreflang={l} lang={l}>
                <img class="flag" src={FLAG_SRC[l]} alt="" />
                {LANG_LABEL[l]}
              </a>
            )
          )
        }
      </nav>
      <a href="#contact" class="btn btn-primary mobile-cta">
        {t.cta} <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
</div>

<script>
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("mobileMenu");
  const header = document.getElementById("nav");
  if (toggle && menu && header) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      header.classList.toggle("menu-open", open);
      if (open) {
        menu.hidden = false;
        document.body.style.overflow = "hidden";
      } else {
        menu.hidden = true;
        document.body.style.overflow = "";
      }
    };
    toggle.addEventListener("click", () => {
      const open = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!open);
    });
    menu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => setOpen(false));
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
    const mql = window.matchMedia("(min-width: 881px)");
    mql.addEventListener("change", (e) => {
      if (e.matches) setOpen(false);
    });
  }
</script>
